{
  "name": "workprint",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "electron:dev": "electron .",
    "build:standalone": "next build && node scripts/copy-standalone-assets.js",
    "build:backend": "scripts/build-backend.sh",
    "electron:pack": "npm run build:standalone && electron-builder --mac --dir",
    "electron:dist": "npm run build:standalone && electron-builder --mac"
  },
  "dependencies": {
    "next": "^16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.17",
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "9.39.1",
    "eslint-config-next": "^16.2.10",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3"
  },
  "build": {
    "appId": "com.workprint.desktop",
    "productName": "Workprint",
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      { "from": "dist-backend", "to": "backend", "filter": ["**/*"] }
    ],
    "afterPack": "scripts/after-pack.js",
    "mac": {
      "icon": "electron/icon.icns",
      "category": "public.app-category.developer-tools",
      "identity": null
    },
    "directories": {
      "output": "release"
    }
  }
}

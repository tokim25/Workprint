{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workprint Finding",
  "type": "object",
  "required": [
    "id",
    "statement",
    "evidence_ids",
    "reasoning",
    "confidence"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "statement": {
      "type": "string"
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "reasoning": {
      "type": "string"
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low",
        "unknown"
      ]
    },
    "alternative_explanations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "classification": {
      "enum": [
        "measured",
        "estimated",
        "qualitative",
        "unknown"
      ]
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workprint Observation",
  "type": "object",
  "required": [
    "id",
    "timestamp",
    "source",
    "source_type",
    "actor",
    "activity",
    "statement",
    "evidence_refs",
    "reliability",
    "metadata"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "activity": {
      "enum": [
        "question",
        "suggestion",
        "evaluation",
        "decision",
        "implementation",
        "artifact",
        "observation",
        "unknown"
      ]
    },
    "statement": {
      "type": "string",
      "minLength": 1
    },
    "artifact": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "reliability": {
      "enum": [
        "high",
        "medium",
        "low",
        "unknown"
      ]
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}

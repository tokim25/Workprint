{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workprint Report",
  "type": "object",
  "required": [
    "project",
    "scope",
    "evidence",
    "findings",
    "unknowns"
  ],
  "properties": {
    "project": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "report_type": {
      "enum": [
        "validation",
        "timeline",
        "attribution",
        "executive",
        "portfolio",
        "detailed"
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}

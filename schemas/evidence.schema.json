{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workprint Evidence Record",
  "type": "object",
  "required": [
    "id",
    "source_type",
    "observation",
    "reliability"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "source_type": {
      "type": "string"
    },
    "source_name": {
      "type": "string"
    },
    "source_locator": {
      "type": "string"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "event_time": {
      "type": [
        "string",
        "null"
      ]
    },
    "actor": {
      "type": [
        "string",
        "null"
      ]
    },
    "activity": {
      "type": [
        "string",
        "null"
      ]
    },
    "artifact": {
      "type": [
        "string",
        "null"
      ]
    },
    "observation": {
      "type": "string"
    },
    "reliability": {
      "enum": [
        "high",
        "medium",
        "low",
        "unknown"
      ]
    },
    "completeness": {
      "enum": [
        "complete",
        "partial",
        "unknown"
      ]
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
